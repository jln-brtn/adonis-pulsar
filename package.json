{
  "name": "adonis-pulsar",
  "description": "AdonisJS v7 wrapper for Apache Pulsar",
  "version": "0.2.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/src/types/main.js",
    "./pulsar_provider": "./build/providers/pulsar_provider.js",
    "./commands": "./build/commands/index.js",
    "./services/main": "./build/services/main.js"
  },
  "scripts": {
    "clean": "del-cli build",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "copy:stubs": "copyfiles \"stubs/**/*.stub\" build",
    "copy:commands": "copyfiles \"commands/commands.json\" build",
    "compile": "npm run clean && npm run build && npm run copy:stubs && npm run copy:commands",
    "prepublishOnly": "npm run compile"
  },
  "keywords": [
    "adonisjs",
    "pulsar",
    "apache-pulsar",
    "message-queue"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "pulsar-client": "^1.11.0"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/node": "^22.0.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^6.0.0",
    "typescript": "^5.6.0"
  }
}
